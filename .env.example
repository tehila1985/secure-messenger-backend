# Optional environment configuration for Secure Messenger
# Copy this file to .env and customize values as needed.

SECRET_KEY=change-this-secret-key
TOKEN_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256
DATABASE_URL=sqlite:///./messenger.db
# Optional: base64-encoded 32-byte encryption key.
# If omitted, the server derives a key from SECRET_KEY.
# ENCRYPTION_KEY=base64encoded32bytekey==
